MONGODB_URI=mongodb://localhost:27017/study-tracker
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Email OTP verification (optional) ---
# Set to "true" to require users to verify their email with a 6-digit OTP (5-min expiry)
REQUIRE_EMAIL_OTP=false
# SMTP credentials (e.g. Gmail App Password, Mailtrap, SendGrid, Brevo, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youremail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Study Tracker <youremail@gmail.com>"
